# ─────────────────────────────────────────────────────────────
# JobPA 환경변수 (Manus → 자체 인프라 이전용)
# 이 파일을 복사해서 .env 로 만들고 값을 채우세요:  cp .env.example .env
# .env 는 절대 git 에 커밋하지 마세요 (.gitignore 에 포함됨).
# ─────────────────────────────────────────────────────────────

# [필수] 데이터베이스 — 본인 TiDB Cloud 계정의 연결 문자열
# TiDB Cloud 콘솔 > Cluster > Connect > "Connect with: General / mysql2" 에서 확인.
# 형식: mysql://<user>:<password>@<host>:4000/<database>?ssl={"rejectUnauthorized":true}
DATABASE_URL=

# [데이터 이전용] Manus 기존 DB 연결 문자열 (데이터 덤프 뜰 때만 임시로 사용)
# Manus 프로젝트의 환경변수/시크릿 화면에서 DATABASE_URL 값을 그대로 복사.
MANUS_DATABASE_URL=

# [필수] 세션 쿠키 서명용 비밀키 (아무 긴 랜덤 문자열)
# 생성 예:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# 서버 포트 (기본 3000)
PORT=3000
NODE_ENV=development

# ─────────────────────────────────────────────────────────────
# 인증 (Manus OAuth 대체) — 이전 단계에서 자체 인증으로 교체 예정
# 아래는 기존 Manus OAuth 변수 (자체 인증 붙이기 전 참고용)
# ─────────────────────────────────────────────────────────────
VITE_APP_ID=
OAUTH_SERVER_URL=
OWNER_OPEN_ID=

# ─────────────────────────────────────────────────────────────
# AI / LLM (Manus Forge 대체)
# 기존 코드는 Forge 의 OpenAI 호환 엔드포인트로 gemini-2.5-flash 를 호출함.
# 교체 옵션 A) OpenAI:     BASE_URL 비우고 OpenAI 키 사용
# 교체 옵션 B) Google Gemini OpenAI 호환 엔드포인트 사용
# ─────────────────────────────────────────────────────────────
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=gemini-2.5-flash

# (기존 Manus Forge 변수 — 자체 LLM 으로 교체 전까지 호환용)
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# ─────────────────────────────────────────────────────────────
# 파일 저장소 (Manus Forge storage 대체) — 자체 S3 또는 로컬 디스크
# ─────────────────────────────────────────────────────────────
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=

# ─────────────────────────────────────────────────────────────
# 채용공고 외부 API (이미 Manus 와 무관한 직접 호출 — 키만 있으면 됨)
# ─────────────────────────────────────────────────────────────
RAPIDAPI_KEY=
SARAMIN_API_KEY=

# JobPA local environment template
# Copy this file to .env and fill in local/staging values.
# Never commit .env.

# Database
DATABASE_URL=
MANUS_DATABASE_URL=

# App/runtime
PORT=3000
NODE_ENV=development
APP_BASE_URL=http://localhost:3000
JWT_SECRET=

# Legacy Manus OAuth compatibility
VITE_APP_ID=
OAUTH_SERVER_URL=
OWNER_OPEN_ID=

# LLM provider
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=gemini-2.5-flash

# Legacy Forge compatibility
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# File storage
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=

# Job data providers
RAPIDAPI_KEY=
SARAMIN_API_KEY=

# Google OAuth and Gmail integration
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
GOOGLE_GMAIL_REDIRECT_URI=http://localhost:3000/api/integrations/gmail/callback
